generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String             @id @default(uuid()) @db.Uuid
  email              String             @unique
  password_hash      String?
  full_name          String
  avatar_url         String?
  timezone           String             @default("UTC")
  currency           String             @default("USD")
  is_verified        Boolean            @default(false)
  strategies         Strategy[]
  backtestresults    BacktestResult[]
  refresh_tokens     RefreshToken[]
  auth_accounts      AuthAccount[]
  email_verification EmailVerification?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Strategy {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  code            String
  asset_symbol    String
  timeframe       String
  is_public       Boolean          @default(false)
  status          Status           @default(active)
  version         Int              @default(1)
  backtestresults BacktestResult[]
  user_id         String           @db.Uuid
  user            User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model BacktestResult {
  id               String               @id @default(uuid()) @db.Uuid
  job_id           String
  strategy_id      String               @db.Uuid
  user_id          String               @db.Uuid
  status           BacktestResultStatus @default(pending)
  start_date       DateTime
  end_date         DateTime
  initial_capital  Decimal              @db.Decimal(15, 2)
  final_capital    Decimal?             @db.Decimal(15, 2)
  total_return_pct Decimal?             @db.Decimal(10, 4)
  max_drawdown_pct Decimal?             @db.Decimal(10, 4)
  win_rate         Decimal?             @db.Decimal(5, 2)
  sharpe_ratio     Decimal?             @db.Decimal(8, 4)
  total_trades     Int?
  ai_analysis      String?
  created_at       DateTime             @default(now())
  strategy         Strategy             @relation(fields: [strategy_id], references: [id], onDelete: Cascade)
  user             User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  token_hash String   @unique
  user_id    String   @db.Uuid
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())
}

model AuthAccount {
  id          String   @id @default(uuid()) @db.Uuid
  provider    String
  provider_id String
  user_id     String   @db.Uuid
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at  DateTime @default(now())

  @@unique([provider, provider_id])
}

model EmailVerification {
  id         String   @id @default(uuid()) @db.Uuid
  token      String   @unique
  user_id    String   @unique @db.Uuid
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())
  expires_at DateTime
}

model Ohlcv {
  id        String   @id @default(cuid())
  time      DateTime @db.Timestamptz(3)
  symbol    String
  timeframe String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float?

  @@index([symbol, timeframe, time])
}

enum Status {
  active
  paused
  archived
}

enum BacktestResultStatus {
  pending
  running
  completed
  failed
}
